<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Jogo da Velha - Estudo</title>
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; }
        
        /* O segredo para o tabuleiro: GRID */
        .tabuleiro {
            display: grid;
            grid-template-columns: repeat(3, 100px); /* 3 colunas de 100px */
            grid-template-rows: repeat(3, 100px);    /* 3 linhas de 100px */
            gap: 5px;                               /* Espaço entre as células */
            margin-top: 20px;
        }

        .celula {
            width: 100px;
            height: 100px;
            font-size: 40px;
            font-weight: bold;
            cursor: pointer;
            background-color: #f0f0f0;
            border: 2px solid #333;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        #botao-reiniciar {
            margin-top: 20px;
            padding: 10px 20px;
            cursor: pointer;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 5px;
        }
    </style>
</head>
<body>

    <h1>Jogo da Velha</h1>

    <div id="tabuleiro-jogo" class="tabuleiro">
        <button class="celula"></button>
        <button class="celula"></button>
        <button class="celula"></button>
        <button class="celula"></button>
        <button class="celula"></button>
        <button class="celula"></button>
        <button class="celula"></button>
        <button class="celula"></button>
        <button class="celula"></button>
    </div>

    <button id="botao-reiniciar">Reiniciar o jogo</button>

    <script>
        // 1. SELEÇÃO DE ELEMENTOS
        const celulas = document.querySelectorAll(".celula");
        const botaoReiniciar = document.getElementById("botao-reiniciar");

        // 2. ESTADO DO JOGO
        let vezdoX = true; // Controla se o próximo clique é X ou O

        // 3. FUNÇÕES PRINCIPAIS
        function iniciarJogo() {
            vezdoX = true; // Reinicia para começar com X
            
            celulas.forEach(celula => {
                celula.textContent = ""; // Limpa o texto
                
                /* DICA: Usamos {once: true} para que o jogador não consiga 
                   clicar na mesma casa duas vezes na mesma rodada. 
                */
                celula.removeEventListener('click', tratarClick); // Remove o antigo para não duplicar
                celula.addEventListener('click', tratarClick, { once: true });
            });
        }

        function tratarClick(evento) {
            // O 'target' é o elemento que recebeu o clique
            const casaClicada = evento.target;
            
            // Define o símbolo com base na vez
            casaClicada.textContent = vezdoX ? "X" : "O";

            // Alterna o valor de vezdoX (true vira false, false vira true)
            vezdoX = !vezdoX;
            
            // Aqui futuramente você pode chamar uma função: checarVencedor();
        }

        // 4. INICIALIZAÇÃO E EVENTOS
        botaoReiniciar.addEventListener('click', iniciarJogo);
        
        // Inicia o jogo assim que a página carrega
        iniciarJogo();

    </script>
</body>
</html>
